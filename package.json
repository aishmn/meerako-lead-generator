    "electron": "^34.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
