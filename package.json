{
  "name": "leadforge-pro",
  "productName": "Meerako Lead Generator",
  "version": "1.0.0",
  "description": "Local-first B2B lead generation and management desktop app",
  "main": ".vite/build/index.js",
  "author": "Internal Team",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "electron-forge start",
    "build": "electron-forge package",
    "make": "electron-forge make",
    "make:win": "electron-forge make --platform=win32 --arch=x64",
    "make:win:mac": "mkdir -p .wine-forge && PATH=\"$(pwd)/scripts:$PATH\" WINEPREFIX=\"$(pwd)/.wine-forge\" WINEDLLOVERRIDES=\"winemenubuilder.exe=d\" WINEDEBUG=-all electron-forge make --platform=win32 --arch=x64",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "dist:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.yourcompany.yourapp",
    "productName": "YourApp",
    "win": {
      "target": ["nsis"]
    }
  },
  "config": {},
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
