# Environment Configuration
NODE_ENV=development

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/leadforge_pro
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis Configuration (for caching and job queues)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d
BCRYPT_ROUNDS=12

# Email Configuration (SendGrid)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=LeadForge Pro

# Email Tracking
EMAIL_TRACKING_DOMAIN=tracking.yourcompany.com
EMAIL_TRACKING_ENABLED=true

# Lead Data Providers (configure at least one)
APOLLO_API_KEY=
ZOOMINFO_API_KEY=
CLEARBIT_API_KEY=
LUSHAAPI_KEY=

# Email Validation
ZEROBOUNCE_API_KEY=
HUNTER_API_KEY=
NEVERBOUNCE_API_KEY=

# Application Settings
APP_NAME=LeadForge Pro
APP_URL=http://localhost:5173
API_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=.csv,.xlsx,.xls

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# Monitoring
SENTRY_DSN=
DATADOG_API_KEY=

# Feature Flags
FEATURE_AI_SCORING=false
FEATURE_INTENT_DATA=false
FEATURE_CRM_SYNC=false
